# ── GOAT Network ──────────────────────────────────────────────────────────
# Verify current values at https://docs.goat.network (testnet chain id / RPC / explorer).
GOAT_CHAIN_ID=48816
GOAT_RPC_URL=https://rpc.testnet3.goat.network
GOAT_EXPLORER_URL=https://explorer.testnet3.goat.network

# ── Payment token (x402) ──────────────────────────────────────────────────
# ERC-3009 (transferWithAuthorization) / Permit2 stablecoin the GOAT facilitator settles.
TIAGOH_PAYMENT_TOKEN=0x0000000000000000000000000000000000000000
# Set facilitatorUrl in tiagoh.config.json to switch the gateway to real verify+settle.
X402_FACILITATOR_URL=
X402_FACILITATOR_KEY=

# ── e2e / on-chain settle ─────────────────────────────────────────────────
# TIAGOH_ONCHAIN=1 + PRIVATE_KEY makes `pnpm --filter @tiagoh/e2e demo` anchor real receipts.
TIAGOH_ONCHAIN=0
PRIVATE_KEY=
TIAGOH_MAX_SESSION=5

# ── Deployed tiagoh contracts (filled after `forge script` deploy) ─────────
RECEIPT_REGISTRY_ADDRESS=
REVENUE_SPLIT_ADDRESS=
CASCADE_CONTROLLER_ADDRESS=
PAYMENT_CHANNEL_ADDRESS=
QUALITY_BOND_ADDRESS=
ESCROW_VAULT_ADDRESS=
DISPUTE_ARBITER_ADDRESS=
REPUTATION_SCORER_ADDRESS=
TOOL_AUCTION_ADDRESS=
AGENT_REGISTRY_ADDRESS=

# ── ERC-8004 registries on GOAT (reuse the canonical deployment) ───────────
ERC8004_IDENTITY_REGISTRY=0x8004...
ERC8004_REPUTATION_REGISTRY=0x8004...
ERC8004_VALIDATION_REGISTRY=0x8004...

# ── Seller / buyer wallet (NEVER commit a real key) ────────────────────────
TIAGOH_PRIVATE_KEY=
TIAGOH_PAY_TO=

# ── Governance / mainnet hardening (see docs/SECURITY.md) ──────────────────
# GOVERNANCE = the Safe multisig or TimelockController that owns the contracts.
GOVERNANCE=
MIN_DELAY=172800
TIMELOCK_PROPOSER=
TIMELOCK_EXECUTOR=0x0000000000000000000000000000000000000000
# BitVM2 optimistic arbiter config (authorize on bond/escrow only after the verifier is proven).
BITVM2_ARBITER_ADDRESS=
BITVM2_VERIFIER_ADDRESS=
PROPOSAL_BOND=1000000000
CHALLENGE_WINDOW=86400

# ── Autonomous buyer (Claude) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
TIAGOH_AGENT_LIVE=0

# ── Dashboard (client-side, no backend) ────────────────────────────────────
NEXT_PUBLIC_GOAT_CHAIN_ID=48816
NEXT_PUBLIC_GOAT_RPC_URL=https://rpc.testnet3.goat.network
NEXT_PUBLIC_GOAT_EXPLORER_URL=https://explorer.testnet3.goat.network
